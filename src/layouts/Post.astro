---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';
import { useTranslations } from '../i18n/ui';
import type { Lang } from '../lib/i18n';

interface Props {
  post: CollectionEntry<'posts'>;
  lang: Lang;
}
const { post, lang } = Astro.props;
const t = useTranslations(lang);
const { title, date, summary, tags, notebook } = post.data;
const dateStr = date.toISOString().slice(0, 10);
---

<Base title={title} description={summary} article={{ publishedTime: date, tags }} lang={lang}>
  <article class="prose">
    <header>
      <span class="eyebrow">{t.writing.eyebrow}</span>
      <h1>{title}</h1>
      <p class="entry-meta">
        <time datetime={dateStr}>{dateStr}</time>
        {tags.length ? <span> · {tags.join(' · ')}</span> : null}
        {notebook ? <span> · <a href={notebook}>{t.writing.notebook} ↗</a></span> : null}
      </p>
    </header>
    <slot />
    {notebook ? (
      <Fragment>
        <hr />
        <p class="subtle mono">{t.writing.notebook}: <a href={notebook}>{notebook}</a></p>
      </Fragment>
    ) : null}
  </article>
</Base>
