---
import { site } from '../config/site';
import { ui, useTranslations } from '../i18n/ui';
import { getLang, localizePath, stripLang, counterpart, OTHER, type Lang } from '../lib/i18n';

interface Props {
  lang?: Lang;
}
const path = Astro.url.pathname;
const { lang = getLang(path) } = Astro.props;
const t = useTranslations(lang);
const p = (x: string) => localizePath(lang, x);
const canonical = stripLang(path);

const nav = [
  { href: p('/writing/'), label: t.nav.writing, match: '/writing' },
  { href: p('/demos/'), label: t.nav.demos, match: '/demos' },
  { href: p('/about/'), label: t.nav.about, match: '/about' },
];
const isActive = (m: string) => canonical.startsWith(m);

const otherHref = counterpart(lang, path);
const otherName = ui[OTHER[lang]].langName;
---

<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href={p('/')}>{site.handle}</a>
    <nav class="nav-links" aria-label="Primary">
      {nav.map((n) => (
        <a href={n.href} aria-current={isActive(n.match) ? 'page' : undefined}>{n.label}</a>
      ))}
      <a class="lang-switch" href={otherHref} hreflang={OTHER[lang]}>{otherName}</a>
      <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle colour theme">
        ◐
      </button>
    </nav>
  </div>
</header>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const el = document.documentElement;
    const next = el.dataset.theme === 'dark' ? 'light' : 'dark';
    el.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
