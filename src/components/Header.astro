---
import { site } from '../config/site';
import { ui } from '../i18n/ui';
import { getLang, localizePath, counterpart, OTHER, type Lang } from '../lib/i18n';

interface Props {
  lang?: Lang;
}
const path = Astro.url.pathname;
const { lang = getLang(path) } = Astro.props;
const t = ui[lang];
const p = (x: string) => localizePath(lang, x);

const otherHref = counterpart(lang, path);
const otherName = ui[OTHER[lang]].langName;

// Brand-mark SVG paths (24x24 viewBox), rendered as a glyph inside a dark circle.
const GITHUB =
  'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12';
const LINKEDIN =
  'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z';
const RSS =
  'M19.199 24C19.199 13.467 10.533 4.8 0 4.8V0c13.165 0 24 10.835 24 24h-4.801zM3.291 17.415c1.814 0 3.293 1.479 3.293 3.295 0 1.813-1.485 3.29-3.301 3.29C1.47 24 0 22.526 0 20.71s1.475-3.294 3.291-3.295zM15.909 24h-4.665c0-6.169-5.075-11.245-11.244-11.245V8.09c8.727 0 15.909 7.184 15.909 15.91z';
const EMAIL =
  'M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z';
---

<header class="site-header">
  <div class="wrap">
    <div class="bar">
      <a class="brand" href={p('/')}>{site.title}</a>
      <div class="header-controls">
        <a class="lang-switch" href={otherHref} hreflang={OTHER[lang]}>{otherName}</a>
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle colour theme">
          ◐
        </button>
      </div>
    </div>
    <p class="site-bio">{t.bio}</p>
    <div class="icon-links">
      <a href={site.links.github} aria-label="GitHub" rel="me">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d={GITHUB} /></svg>
      </a>
      <a href={site.links.linkedin} aria-label="LinkedIn" rel="me">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d={LINKEDIN} /></svg>
      </a>
      <a href={p('/rss.xml')} aria-label="RSS feed">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d={RSS} /></svg>
      </a>
      <a href={`mailto:${site.links.email}`} aria-label="Email">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d={EMAIL} /></svg>
      </a>
    </div>
  </div>
</header>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const el = document.documentElement;
    const next = el.dataset.theme === 'dark' ? 'light' : 'dark';
    el.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
