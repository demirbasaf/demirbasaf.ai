---
import { site } from '../config/site';
import { ui } from '../i18n/ui';
import { getLang, localizePath, counterpart, OTHER, type Lang } from '../lib/i18n';

interface Props {
  lang?: Lang;
}
const path = Astro.url.pathname;
const { lang = getLang(path) } = Astro.props;
const t = ui[lang];
const p = (x: string) => localizePath(lang, x);

const otherHref = counterpart(lang, path);
const otherName = ui[OTHER[lang]].langName;
---

<header class="site-header">
  <div class="wrap">
    <div class="bar">
      <a class="brand" href={p('/')}>{site.title}</a>
      <nav class="nav-links" aria-label="Primary">
        <a href={site.links.github}>github</a>
        <a href={site.links.linkedin}>linkedin</a>
        {site.links.x ? <a href={site.links.x}>x</a> : null}
        <a class="lang-switch" href={otherHref} hreflang={OTHER[lang]}>{otherName}</a>
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle colour theme">
          ◐
        </button>
      </nav>
    </div>
    <p class="site-bio">{t.bio}</p>
  </div>
</header>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const el = document.documentElement;
    const next = el.dataset.theme === 'dark' ? 'light' : 'dark';
    el.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
