---
import '../styles/global.css';
import { site } from '../config/site';
import { ui, bcp47, ogLocale } from '../i18n/ui';
import { localizePath, stripLang, type Lang } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  article?: { publishedTime: Date; tags?: string[] };
  lang: Lang;
}
const { title, article, lang } = Astro.props;
const description = Astro.props.description ?? ui[lang].meta.description;
const fullTitle = title ? `${title} · ${site.title}` : site.title;
const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const ogType = article ? 'article' : 'website';

// hreflang: this same page in each language, plus x-default -> English.
const canonicalPath = stripLang(Astro.url.pathname);
const enHref = new URL(localizePath('en', canonicalPath), site.url).href;
const trHref = new URL(localizePath('tr', canonicalPath), site.url).href;

const keywords = [
  ...site.person.alternateNames,
  'systems engineer',
  'machine learning systems',
  'MoonPay',
  'Lisbon',
].join(', ');

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.title,
  alternateName: site.person.alternateNames,
  url: site.url,
  jobTitle: site.person.jobTitle,
  worksFor: { '@type': 'Organization', name: site.person.worksFor.name, url: site.person.worksFor.url },
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.person.location.city,
    addressCountry: site.person.location.country,
  },
  knowsAbout: site.person.knowsAbout,
  sameAs: site.person.sameAs,
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.title,
  url: site.url,
  inLanguage: bcp47[lang],
  author: { '@type': 'Person', name: site.title, url: site.url },
};

const articleLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      url: canonical,
      inLanguage: bcp47[lang],
      datePublished: article.publishedTime.toISOString(),
      keywords: (article.tags ?? []).join(', '),
      author: { '@type': 'Person', name: site.title, url: site.url },
      publisher: { '@type': 'Person', name: site.title, url: site.url },
      mainEntityOfPage: canonical,
    }
  : null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="canonical" href={canonical} />

<!-- hreflang alternates for the two locales. -->
<link rel="alternate" hreflang="en" href={enHref} />
<link rel="alternate" hreflang="tr" href={trHref} />
<link rel="alternate" hreflang="x-default" href={enHref} />
<link rel="alternate" type="application/rss+xml" title={site.title} href={localizePath(lang, '/rss.xml')} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={site.title} />
<meta name="keywords" content={keywords} />
<meta name="robots" content="index, follow, max-image-preview:large" />

<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={site.title} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={ogLocale[lang]} />
<meta property="og:locale:alternate" content={lang === 'en' ? ogLocale.tr : ogLocale.en} />
{article ? <meta property="article:published_time" content={article.publishedTime.toISOString()} /> : null}
{article?.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />

<!-- Structured data for search engines and AI agents. -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
{articleLd ? <script is:inline type="application/ld+json" set:html={JSON.stringify(articleLd)} /> : null}

<!-- Set the theme before first paint to avoid a flash of the wrong colours. -->
<script is:inline>
  (() => {
    const stored = localStorage.getItem('theme');
    const dark = stored ? stored === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
    document.documentElement.dataset.theme = dark ? 'dark' : 'light';
  })();
</script>
