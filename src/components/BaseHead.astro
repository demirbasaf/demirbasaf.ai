---
import '../styles/global.css';
import { site } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  /** Present on blog posts: switches meta to article + adds Article JSON-LD. */
  article?: { publishedTime: Date; tags?: string[] };
}
const { title, description = site.description, article } = Astro.props;
const fullTitle = title ? `${title} · ${site.title}` : site.title;
const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const ogType = article ? 'article' : 'website';

// Name variants as keywords so every spelling of the name is on the page.
const keywords = [
  ...site.person.alternateNames,
  'systems engineer',
  'machine learning systems',
  'MoonPay',
  'Lisbon',
].join(', ');

// --- schema.org Person: the entity every name variant resolves to ---
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.title,
  alternateName: site.person.alternateNames,
  url: site.url,
  jobTitle: site.person.jobTitle,
  worksFor: { '@type': 'Organization', name: site.person.worksFor.name, url: site.person.worksFor.url },
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.person.location.city,
    addressCountry: site.person.location.country,
  },
  knowsAbout: site.person.knowsAbout,
  sameAs: site.person.sameAs,
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.title,
  url: site.url,
  inLanguage: site.locale,
  author: { '@type': 'Person', name: site.title, url: site.url },
};

const articleLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      url: canonical,
      inLanguage: site.locale,
      datePublished: article.publishedTime.toISOString(),
      keywords: (article.tags ?? []).join(', '),
      author: { '@type': 'Person', name: site.title, url: site.url },
      publisher: { '@type': 'Person', name: site.title, url: site.url },
      mainEntityOfPage: canonical,
    }
  : null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="canonical" href={canonical} />
<link rel="alternate" type="application/rss+xml" title={site.title} href="/rss.xml" />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={site.title} />
<meta name="keywords" content={keywords} />
<meta name="robots" content="index, follow, max-image-preview:large" />

<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={site.title} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content="en_US" />
{article ? <meta property="article:published_time" content={article.publishedTime.toISOString()} /> : null}
{article?.tags?.map((t) => <meta property="article:tag" content={t} />)}
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />

<!-- Structured data for search engines and AI agents. -->
<script type="application/ld+json" set:html={JSON.stringify(personLd)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
{articleLd ? <script type="application/ld+json" set:html={JSON.stringify(articleLd)} /> : null}

<!-- Set the theme before first paint to avoid a flash of the wrong colours. -->
<script is:inline>
  (() => {
    const stored = localStorage.getItem('theme');
    const dark = stored ? stored === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
    document.documentElement.dataset.theme = dark ? 'dark' : 'light';
  })();
</script>
