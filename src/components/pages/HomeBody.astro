---
import { publishedEntries, bareSlug } from '../../lib/entries';
import { useTranslations } from '../../i18n/ui';
import { site } from '../../config/site';
import { localizePath, type Lang } from '../../lib/i18n';
import TimelineSection from './TimelineSection.astro';
import EducationSection from './EducationSection.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const entries = await publishedEntries(lang);
const p = (path: string) => localizePath(lang, path);
---

<section class="prose">
  <span class="eyebrow">{t.about.label}</span>
  <p>{t.about.p1a}<a href={site.person.worksFor.url}>MoonPay</a>{t.about.p1b}</p>
  <p>{t.about.p2}</p>
</section>

<TimelineSection lang={lang} />

<EducationSection lang={lang} />

<section style="margin-top:2.6rem">
  <span class="eyebrow">{t.entries.label}</span>
  <ul class="entry-list" style="margin-top:0">
  {entries.map((e) => (
    <li class="entry">
      <a href={p(`/${bareSlug(e)}/`)}>
        <div class="entry-title">
          {e.data.title}
          {e.data.status === 'wip' ? <span class="badge">{t.entry.wip}</span> : null}
        </div>
        <div class="entry-meta">
          {e.data.date.toISOString().slice(0, 10)}
        </div>
        <div class="entry-summary">{e.data.summary}</div>
      </a>
    </li>
  ))}
  </ul>
</section>
