---
import { site } from '../../config/site';
import { useTranslations } from '../../i18n/ui';
import type { Lang } from '../../lib/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<article class="prose">
  <span class="eyebrow">{t.about.label}</span>
  <h1>Ali Furkan Demirbaş</h1>
  <p>
    {t.about.p1a}<a href={site.person.worksFor.url}>MoonPay</a>{t.about.p1b}
  </p>
  <p>{t.about.p2}</p>
  <p class="mono" style="font-size:0.9rem">
    <a href={site.links.github}>github</a>
    {site.links.x ? <Fragment> · <a href={site.links.x}>x</a></Fragment> : null}
  </p>
  <p class="subtle" style="font-size:0.85rem">{t.about.variants}</p>
</article>
